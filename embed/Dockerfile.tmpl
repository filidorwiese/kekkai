FROM {{.DebianImage}}

# Builtin + user apt packages (§5.1). gh is not in Debian repos, so the
# GitHub CLI apt repo is added first; the keyring file needs no gpg tooling.
RUN export DEBIAN_FRONTEND=noninteractive \
 && apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates curl \
 && install -d -m 0755 /etc/apt/keyrings \
 && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
 && chmod 0644 /etc/apt/keyrings/githubcli-archive-keyring.gpg \
 && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends{{range .AptPackages}} {{.}}{{end}} \
 && rm -rf /var/lib/apt/lists/*

# Non-root sandbox user (§6.3): baked with the host's uid/gid (specs/018) so
# workspace files stay owned by the host user AND group. Host-side gate
# guarantees ids >= 1000; the getent guard reuses a pre-existing group with
# that gid instead of failing the build.
RUN (getent group {{.Gid}} >/dev/null || groupadd -g {{.Gid}} kekkai) \
 && useradd -m -u {{.Uid}} -g {{.Gid}} -s /bin/bash kekkai

# bash history persists in the /commandhistory volume (§6.3). PROMPT_COMMAND
# appends per command, so a killed session loses at most the in-flight line.
RUN mkdir -p /commandhistory /workspace /home/kekkai/.claude \
 && touch /commandhistory/.bash_history \
 && chown -R {{.Uid}}:{{.Gid}} /commandhistory /workspace /home/kekkai \
 && printf 'export HISTFILE=/commandhistory/.bash_history\nexport HISTSIZE=10000\nexport HISTFILESIZE=10000\nexport PROMPT_COMMAND='"'"'history -a'"'"'\n' \
      >> /home/kekkai/.bashrc \
 && chown {{.Uid}}:{{.Gid}} /home/kekkai/.bashrc

# Node via nvm at image build time (§6.3): pinned nvm release tag, version
# selector from image.node_version. Everything installs as the kekkai user
# into its home, so runtime `npm install -g` never needs sudo and no
# root-owned files land under /home/kekkai. No NPM_CONFIG_PREFIX: nvm
# refuses to operate with an npm prefix set; globals live in the nvm
# version dir.
#
# Build-time downloads (nvm installer/repo, nodejs.org tarballs, npm
# registry) run on the docker daemon's host network — the egress firewall
# does not exist until container start (§9). These domains are never
# firewall inputs: not in network.allowed_domains, not in the §5.4 builtin
# set.
#
# BASH_ENV sources nvm.sh into every non-interactive bash — the installer's
# documented pattern for making `nvm` callable from build steps. bash
# silently skips the file until it exists.
ENV NVM_DIR=/home/kekkai/.nvm
ENV BASH_ENV=/home/kekkai/.nvm-bash-env
SHELL ["/bin/bash", "-c"]
USER kekkai
RUN curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/{{.NvmVersion}}/install.sh | bash \
 && printf '. "$NVM_DIR/nvm.sh"\n' > "$BASH_ENV"

# Install Node and freeze it: `lts` resolves to the current LTS here at
# build time and never retroactively (§6.1 — the selector string, not the
# resolved version, is what enters the image hash). The `current` symlink
# gives version-independent paths for the /usr/local/bin links and PATH.
# Nonexistent versions are normally caught by the host-side pre-build check
# (specs/017); when that check was inconclusive (degraded network), nvm's
# native "Version not found" error surfaces here.
RUN nvm install {{.NodeInstallArg}} \
 && nvm alias default "$(nvm current)" \
 && ln -s "$NVM_DIR/versions/node/$(nvm current)" "$NVM_DIR/current"

RUN npm install -g @anthropic-ai/claude-code@{{.ClaudeVersion}}

# node/npm/npx/claude reachable from every exec path — docker exec, sh -c,
# subprocesses — without profile sourcing (§6.3): stable symlinks in
# /usr/local/bin plus PATH onto the live nvm bin dir (the PATH entry also
# covers binaries added later by runtime `npm install -g`, and outranks any
# Debian nodejs from user apt_packages).
USER root
RUN ln -s /home/kekkai/.nvm/current/bin/node /usr/local/bin/node \
 && ln -s /home/kekkai/.nvm/current/bin/npm /usr/local/bin/npm \
 && ln -s /home/kekkai/.nvm/current/bin/npx /usr/local/bin/npx \
 && ln -s /home/kekkai/.nvm/current/bin/claude /usr/local/bin/claude
ENV PATH=/home/kekkai/.nvm/current/bin:$PATH

# The ONLY sudoers grant: the firewall script (§6.3). No docker CLI in image.
# sudo resets the environment, so the four firewall input vars (§9) are
# whitelisted via env_keep scoped to that one command — not SETENV, which
# would let arbitrary env through.
COPY init-firewall.sh /usr/local/bin/init-firewall.sh
RUN chmod 0755 /usr/local/bin/init-firewall.sh \
 && { echo 'kekkai ALL=(root) NOPASSWD: /usr/local/bin/init-firewall.sh'; \
      echo 'Defaults!/usr/local/bin/init-firewall.sh env_keep += "ALLOW_ALL ALLOW_GITHUB ALLOWED_DOMAINS ALLOWED_CIDRS"'; \
    } > /etc/sudoers.d/kekkai \
 && chmod 0440 /etc/sudoers.d/kekkai

USER kekkai
WORKDIR /workspace
ENV SHELL=/bin/bash

# Startup line first: the concrete Node version is only known in-image (nvm
# resolved the selector at build), and the claude version was rendered at
# build — so the line stays correct even on the §6.2 offline-fallback image.
# Then firewall init, which must succeed before claude starts (§7.2).
# KEKKAI_SYSTEM_PROMPT expansions are quoted — the multiline sandbox context
# must arrive byte-for-byte; CLAUDE_ARGS stays unquoted by design (flag
# string). Empty/unset prompt var → identical command line to pre-011.
CMD ["/bin/sh", "-c", "echo \"kekkai sandbox: node $(node -v), claude {{.ClaudeVersion}}\" && sudo /usr/local/bin/init-firewall.sh && if [ -n \"$KEKKAI_SYSTEM_PROMPT\" ]; then exec claude $CLAUDE_ARGS --append-system-prompt \"$KEKKAI_SYSTEM_PROMPT\"; else exec claude $CLAUDE_ARGS; fi"]
