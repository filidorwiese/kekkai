FROM {{.Base}}

ARG TZ
ENV TZ="$TZ"

RUN groupmod -n kekkai node && \
    usermod  -l kekkai -d /home/kekkai -m node

RUN apt-get update && apt-get install -y --no-install-recommends \
{{- range .AptPackages }}
  {{.}} \
{{- end }}
  && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /usr/local/share/npm-global && \
  chown -R kekkai:kekkai /usr/local/share

RUN mkdir /commandhistory \
  && touch /commandhistory/.zsh_history \
  && chown -R kekkai:kekkai /commandhistory

ENV DEVCONTAINER=true

RUN mkdir -p /workspace /home/kekkai/.claude /etc/kekkai && \
  chown -R kekkai:kekkai /workspace /home/kekkai/.claude

WORKDIR /workspace

ARG DOCKER_CLI_VERSION={{.DockerCliVersion}}
RUN ARCH=$(uname -m) && \
  curl -fsSL -o /tmp/docker.tgz "https://download.docker.com/linux/static/stable/${ARCH}/docker-${DOCKER_CLI_VERSION}.tgz" && \
  tar -xzf /tmp/docker.tgz -C /tmp docker/docker && \
  mv /tmp/docker/docker /usr/local/bin/docker && \
  chmod +x /usr/local/bin/docker && \
  rm -rf /tmp/docker /tmp/docker.tgz

USER kekkai

ENV NPM_CONFIG_PREFIX=/usr/local/share/npm-global
ENV PATH=$PATH:/usr/local/share/npm-global/bin

ENV SHELL=/bin/zsh
ENV EDITOR=nano
ENV VISUAL=nano

RUN printf '%s\n' \
  'export HISTFILE=/commandhistory/.zsh_history' \
  'HISTSIZE=100000' \
  'SAVEHIST=100000' \
  'setopt INC_APPEND_HISTORY' \
  > /home/kekkai/.zshrc

ARG CLAUDE_CODE_VERSION={{.ClaudeCodeVersion}}
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

COPY init-firewall.sh /usr/local/bin/init-firewall.sh
USER root
RUN chmod +x /usr/local/bin/init-firewall.sh && \
  echo "kekkai ALL=(root) NOPASSWD: /usr/local/bin/init-firewall.sh" > /etc/sudoers.d/kekkai-firewall && \
  chmod 0440 /etc/sudoers.d/kekkai-firewall
USER kekkai
